pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    component: jenkins-agent
spec:
  containers:
  - name: build-tools
    image: docker:24.0.7-dind
    command:
    - sleep
    args:
    - infinity
    volumeMounts:
    - mountPath: /var/run/docker.sock
      name: docker-sock
    - mountPath: /usr/local/bin/kubectl
      name: kubectl-bin
  volumes:
  - name: docker-sock
    hostPath:
      path: /var/run/docker.sock
  - name: kubectl-bin
    hostPath:
      path: /usr/local/bin/kubectl
'''
        }
    }

    environment {
        REGISTRY_IMAGE = 'order-service:latest'
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                container('build-tools') {
                    echo 'Building container image inside Minikube runtime...'
                    sh "docker build -t ${REGISTRY_IMAGE} ./apps/order-service"
                }
            }
        }

        stage('Kubernetes Deployment') {
            steps {
                container('build-tools') {
                    echo 'Applying manifests to local Kubernetes cluster...'
                    sh "kubectl apply -f k8s/base/deployment.yaml"
                    sh "kubectl apply -f k8s/base/service.yaml"
                }
            }
        }

        stage('Verify Rollout') {
            steps {
                container('build-tools') {
                    echo 'Checking pod deployment status...'
                    sh "kubectl rollout status deployment/order-service --timeout=60s"
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment Pipeline executed successfully! App is active.'
        }
        failure {
            echo 'Pipeline failed. Check pod status:'
            container('build-tools') {
                sh 'kubectl get pods'
            }
        }
    }
}
